# SQLite by default; for deployment use a Postgres URL, e.g. Neon:
# DATABASE_URL=postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///./crm.db

# Where the channel simulator runs (its deployed URL in prod)
CHANNEL_SERVICE_URL=http://localhost:8001
# Public URL of THIS service — the channel calls back to {CRM_PUBLIC_URL}/api/receipts
CRM_PUBLIC_URL=http://localhost:8000

# Shared secret for HMAC-signing receipt callbacks (must match channel service)
WEBHOOK_SECRET=dev-secret-change-me

# AI
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
