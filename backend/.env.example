# SQLite by default; for deployment use a Postgres URL, e.g. Neon:
# DATABASE_URL=postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///./crm.db

# Where the channel simulator runs (its deployed URL in prod)
CHANNEL_SERVICE_URL=http://localhost:8001
# Public URL of THIS service — the channel calls back to {CRM_PUBLIC_URL}/api/receipts
CRM_PUBLIC_URL=http://localhost:8000

# Shared secret for HMAC-signing receipt callbacks (must match channel service)
WEBHOOK_SECRET=dev-secret-change-me

# ---------------------------------------------------------------- AI
# Pick ONE of the two setups below. All AI features (copilot chat, NL->
# segment, message drafts, performance summaries) work with either.

# Option A — Anthropic (paid):
ANTHROPIC_API_KEY=
# AI_MODEL=claude-sonnet-4-6

# Option B — any OpenAI-compatible provider. Free-tier choices:
#
#   Groq (free, fast — recommended):   https://console.groq.com  -> API key
#     AI_BASE_URL=https://api.groq.com/openai/v1
#     AI_MODEL=llama-3.3-70b-versatile
#
#   Google Gemini (free AI Studio key): https://aistudio.google.com/apikey
#     AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#     AI_MODEL=gemini-2.0-flash
#
#   OpenRouter (free models):           https://openrouter.ai/keys
#     AI_BASE_URL=https://openrouter.ai/api/v1
#     AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
#   Ollama (local, no key needed — set AI_API_KEY=ollama):
#     AI_BASE_URL=http://localhost:11434/v1
#     AI_MODEL=llama3.2
#
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=claude-sonnet-4-6
